# ──────────────────────────────────────────────────────────────
# Copia este archivo a .env y ajusta los valores según necesites.
# Los valores por defecto funcionan con docker-compose.dev.yml.
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL=postgres://chat:chat@localhost:5432/chat

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
# Genera secretos seguros en producción:
#   openssl rand -base64 32
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-32b
JWT_REFRESH_PEPPER=dev-refresh-pepper-change-in-production-x
ACCESS_TTL=900        # 15 minutos (segundos)
REFRESH_TTL=2592000   # 30 días   (segundos)

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_REFRESH_WINDOW=60
RATE_LIMIT_DEFAULT_MAX=120
RATE_LIMIT_DEFAULT_WINDOW=60

# ── Almacenamiento S3-compatible ─────────────────────────────
# Dev: MinIO local (docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chat-attachments
S3_PUBLIC_URL=http://localhost:9000/chat-attachments
S3_FORCE_PATH_STYLE=true

# Prod: Cloudflare R2 — descomentar y rellenar
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY=<R2_ACCESS_KEY>
# S3_SECRET_KEY=<R2_SECRET_KEY>
# S3_BUCKET=chat-attachments
# S3_PUBLIC_URL=https://pub-xxx.r2.dev
# S3_FORCE_PATH_STYLE=false

# ── Email ────────────────────────────────────────────────────
EMAIL_FROM=no-reply@chat.local
EMAIL_VERIFY_URL_BASE=http://localhost:5173/verify
EMAIL_RESET_URL_BASE=http://localhost:5173/reset

# ── WebSocket ────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=20   # cliente envía heartbeat cada N segundos
WS_PRESENCE_TTL=60         # segundos hasta que se marca offline sin heartbeat
WS_TICKET_TTL=30           # segundos de validez de un ticket WS de un solo uso
